  <div style="padding: 50px 20px; margin-top:150px; display: flex; gap: 30px; align-items: center; justify-content: center; flex-wrap: wrap;">
    
    <!-- Filter: Dynamisch/Statisch -->
    <div class="filter-group">
      <button class="filter-btn active">Alle</button>
      <button class="filter-btn">Dynamisch</button>
      <button class="filter-btn">Statisch</button>
