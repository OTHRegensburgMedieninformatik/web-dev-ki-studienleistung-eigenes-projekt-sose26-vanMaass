      <button class="filter-btn active">Alle</button>
      <button class="filter-btn">Foto</button>
      <button class="filter-btn">Grafik</button>
    </div>

    <!-- Filter: Farbe -->
    <div class="filter-group">
      <button class="filter-btn active">Alle</button>
      <button class="filter-btn" style="background-color: #FF6B6B; color: white;"></button>
      <button class="filter-btn" style="background-color: #5fcd4e; color: white;"></button>
      <button class="filter-btn" style="background-color: #FFD93D; color: black;"></button>
      <button class="filter-btn" style="background-color: #2C3E50; color: white;"></button>
    </div>

  </div>
  {{>shopgallery}}
